pkgname=radisk
pkgver=0.1.0
pkgrel=1
pkgdesc="Terminal-based radial disk usage visualizer inspired by KDE FileLight"
url="https://github.com/mimobn/radisk"
license=("GPL-3.0-or-later")
arch=("x86_64")
makedepends=("cargo")
depends=("gcc-libs")
source=("radisk-$pkgver.tar.gz::https://github.com/mimobn/radisk/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=("SKIP")

build() {
    cd "radisk-$pkgver"
    cargo build --release
}

package() {
    cd "radisk-$pkgver"
    install -Dm755 "target/release/radisk" -t "$pkgdir/usr/bin"
}
